# Environment Variables for Student Portal Backend
# Copy this file and rename to .env, then fill in your values

# Server Port
PORT=5000

# MongoDB Connection String
# Option 1: Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/student_portal

# Option 2: MongoDB Atlas (Cloud) - Replace with your actual connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/student_portal?retryWrites=true&w=majority
