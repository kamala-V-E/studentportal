# Environment Variables for Student Portal Backend
# Copy this file and rename to .env, then fill in your values

# Server Port
# IMPORTANT: api.js hardcodes API_BASE = 'http://localhost:5000/api'
# This MUST stay 5000 unless you also update API_BASE in api.js
PORT=5000

# MongoDB Connection String (Atlas)
# Use the SRV connection string format provided by Atlas. Replace <username>, <password>, and <dbname> with your credentials.
MONGODB_URI=mongodb://eventportal:event12345@ac-jj84unw-shard-00-00.dv8s1so.mongodb.net:27017,ac-jj84unw-shard-00-01.dv8s1so.mongodb.net:27017,ac-jj84unw-shard-00-02.dv8s1so.mongodb.net:27017/?ssl=true&replicaSet=atlas-do21cx-shard-0&authSource=admin&appName=Cluster0

# Razorpay Settings (Replace with your actual keys from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_default_key
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# SMTP Email Settings
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="College Event Portal <no-reply@collegeportal.edu>"